# Copy to backend/.env and fill in as needed. Never commit the real .env.

# "mock" backends need no credentials and are used for local dev/tests.
# "openai" backends are the real fallback standing in for NVIDIA NeMo/NIM.
ASR_BACKEND=mock
NLP_BACKEND=mock

OPENAI_API_KEY=
ASR_MODEL=whisper-1
NLP_MODEL=gpt-4o-mini

POSTGRES_DSN=postgresql+psycopg2://clinicalvoice:clinicalvoice@localhost:5432/clinicalvoice
REDIS_URL=redis://localhost:6379/0
